{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],

    "module": "ESNext",
    "moduleResolution": "Node",

    "outDir": "./dist",
    "rootDir": "./src",

    "declaration": true,
    "jsx": "react-jsx",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}